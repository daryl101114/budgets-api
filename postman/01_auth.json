{
  "name": "Auth",
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/authentication/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"postman@example.com\",\n  \"password\": \"Test1234\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response confirms user created', () => {",
              "    pm.expect(pm.response.text()).to.include('created');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Authenticate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/authentication/authenticate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"postman@example.com\",\n  \"password\": \"Test1234\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "",
              "// Extract JWT from Set-Cookie header and store for all subsequent requests",
              "const setCookie = pm.response.headers.get('Set-Cookie');",
              "pm.test('JWT cookie is present', () => pm.expect(setCookie).to.include('app.at='));",
              "const match = setCookie && setCookie.match(/app\\.at=([^;]+)/);",
              "if (match) {",
              "    pm.collectionVariables.set('token', match[1]);",
              "    console.log('Token stored successfully');",
              "}"
            ]
          }
        }
      ]
    }
  ]
}